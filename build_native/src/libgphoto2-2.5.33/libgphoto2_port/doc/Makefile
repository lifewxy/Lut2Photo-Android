all-local:
	@echo "Dummy target $@ without gtk-doc."

dist-hook:
	@echo "Dummy target $@ without gtk-doc."
	@echo "Re-run configure with gtk-doc and adequate parameters and run make again to build docs."

install-data-local:
	@echo "Dummy target $@ without gtk-doc"
	@echo "Re-run configure with gtk-doc and adequate parameters and run make again to build docs."

